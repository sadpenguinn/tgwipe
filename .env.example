# Obtain at https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Phone number associated with your Telegram account, e.g. +12025551234
TELEGRAM_PHONE=+10000000000

# API key from console.anthropic.com — required only for --ai-filter
ANTHROPIC_API_KEY=

# Optional settings
# TGWIPE_SESSION_NAME=tgwipe
# TGWIPE_REQUEST_DELAY=0.5
# TGWIPE_BATCH_SIZE=100
# TGWIPE_AI_BATCH_SIZE=10
# TGWIPE_AI_MODEL=claude-sonnet-4-6
# TGWIPE_AI_PROMPT=Your custom system prompt here
